# Backend environment variables (Render)
NODE_ENV=production

# MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/stdout?retryWrites=true&w=majority

# JWT Secret for authentication (generate a strong random string)
JWT_SECRET=generate-a-strong-random-string-here

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Frontend URL for CORS
# For production on Vercel: https://your-frontend-vercel-domain.vercel.app
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Server port (Render will set this automatically)
PORT=3001
